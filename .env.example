# ==============================================================
# Rentivo configuration — copy to .env and adjust.
# All app variables use the RENTIVO_ prefix (see rentivo/settings.py).
# Full reference with validation rules: docs/configuration.md
# ==============================================================

# --- Database (MariaDB) ---
# This URL is used by processes running on YOUR machine (make run,
# make migrate, make web-run). Containers started via docker compose
# ignore it — docker-compose.yml pins their DB host to the internal
# `db` service automatically.
RENTIVO_DB_URL=mysql+pymysql://rentivo:rentivo@localhost:3306/rentivo

# MariaDB container provisioning (read by docker-compose.yml, not the app).
# WARNING: MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE are interpolated
# into the containers' DB URL by docker-compose.yml without URL-encoding —
# avoid @ / ? # & = in these values (or percent-encode them yourself).
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=rentivo
MYSQL_USER=rentivo
MYSQL_PASSWORD=rentivo
MYSQL_PORT=3306

# --- Web ---
# Session signing key. REQUIRED in production: with the default value a
# random key is generated at boot and sessions reset on every restart.
# Rotating it also invalidates the users.email_hash blind index — see
# docs/configuration.md before rotating.
RENTIVO_SECRET_KEY=change-me-in-production
# Canonical public origin (no trailing slash) for robots.txt / sitemap.xml /
# OG tags. Leave empty to derive from the incoming request.
RENTIVO_PUBLIC_URL=
# Canonical app URL used inside transactional emails.
RENTIVO_PUBLIC_APP_URL=http://localhost:8000
# One of: production | staging | dev
RENTIVO_ENVIRONMENT=dev

# --- Logging ---
RENTIVO_LOG_LEVEL=INFO
RENTIVO_LOG_JSON=false

# --- WebAuthn / Passkeys ---
RENTIVO_WEBAUTHN_RP_ID=localhost
RENTIVO_WEBAUTHN_RP_NAME=Rentivo
RENTIVO_WEBAUTHN_ORIGIN=http://localhost:8000

# --- Storage (invoice PDFs) ---
# One of: local | s3
RENTIVO_STORAGE_BACKEND=local
RENTIVO_STORAGE_LOCAL_PATH=./invoices
RENTIVO_STORAGE_PREFIX=bills

# S3 (only used when RENTIVO_STORAGE_BACKEND=s3)
RENTIVO_S3_BUCKET=
RENTIVO_S3_REGION=
RENTIVO_S3_ACCESS_KEY_ID=
RENTIVO_S3_SECRET_ACCESS_KEY=
RENTIVO_S3_ENDPOINT_URL=
RENTIVO_S3_PRESIGNED_EXPIRY=604800

# --- Email ---
# One of: local | ses. The local backend writes .eml files to
# RENTIVO_EMAIL_LOCAL_PATH instead of calling AWS.
RENTIVO_EMAIL_BACKEND=local
RENTIVO_EMAIL_LOCAL_PATH=./outbox

# AWS SES (only used when RENTIVO_EMAIL_BACKEND=ses)
RENTIVO_SES_REGION=
RENTIVO_SES_ACCESS_KEY_ID=
RENTIVO_SES_SECRET_ACCESS_KEY=
RENTIVO_SES_ENDPOINT_URL=
RENTIVO_SES_FROM_EMAIL=
RENTIVO_SES_CONFIGURATION_SET=

# --- Google OAuth authentication ---
# Set RENTIVO_GOOGLE_AUTH_ENABLED=true and provide credentials to enable.
RENTIVO_GOOGLE_AUTH_ENABLED=false
RENTIVO_GOOGLE_CLIENT_ID=
RENTIVO_GOOGLE_CLIENT_SECRET=

# --- Field encryption (PII at rest) ---
# One of: base64 | kms. Use kms in production. base64 is reversible
# obfuscation, NOT encryption — anyone with DB access can decode it.
# After switching to kms run: make backfill-encryption
RENTIVO_ENCRYPTION_BACKEND=base64

# AWS KMS (required when RENTIVO_ENCRYPTION_BACKEND=kms: key id + region).
# IMPORTANT: enable deletion protection on the KMS key — losing it means
# losing all encrypted PII permanently.
RENTIVO_KMS_KEY_ID=
RENTIVO_KMS_REGION=
RENTIVO_KMS_ACCESS_KEY_ID=
RENTIVO_KMS_SECRET_ACCESS_KEY=
RENTIVO_KMS_ENDPOINT_URL=

# --- Decryption cache (in front of the encryption backend) ---
# One of: none | memory | redis. Cuts KMS round-trips on hot read paths.
RENTIVO_ENCRYPTION_CACHE_BACKEND=none
RENTIVO_ENCRYPTION_CACHE_TTL_SECONDS=60
RENTIVO_ENCRYPTION_CACHE_MAX_ENTRIES=10000

# --- Generic application cache (KPI rollups etc.) ---
# One of: none | memory | redis
RENTIVO_CACHE_BACKEND=memory
RENTIVO_CACHE_TTL_SECONDS=60
RENTIVO_CACHE_MAX_ENTRIES=2048

# Shared by both caches; required iff either cache backend is redis.
# Use rediss:// + auth in production.
RENTIVO_REDIS_URL=

# --- Bot protection (Cloudflare Turnstile) ---
# Set BOTH keys to enable, leave BOTH empty to disable (enforced at boot).
RENTIVO_TURNSTILE_SITE_KEY=
RENTIVO_TURNSTILE_SECRET_KEY=
RENTIVO_TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# --- Analytics (Google Tag Manager) ---
# GTM-XXXXXXX enables analytics; empty string fully disables it.
RENTIVO_GTM_CONTAINER_ID=

# --- Background job worker ---
RENTIVO_JOB_WORKER_BATCH_SIZE=10
RENTIVO_JOB_WORKER_IDLE_SLEEP_SECONDS=5.0
RENTIVO_JOB_WORKER_STUCK_AFTER_SECONDS=600
