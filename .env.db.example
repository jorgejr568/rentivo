# Compose interpolation and MariaDB provisioning.
# make compose-dev uses this local-only example directly. For the production
# stack, copy it to .env.db and replace every deployment-specific value.

MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=rentivo
MYSQL_USER=rentivo
MYSQL_PASSWORD=rentivo
MYSQL_PORT=3306

RENTIVO_PUBLIC_ORIGIN=https://rentivo.example.com
RENTIVO_WEBAUTHN_RP_ID=rentivo.example.com
RENTIVO_TRUSTED_TLS_TERMINATOR_CIDR=127.0.0.1/32
